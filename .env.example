# TwinLink Unified - Environment Variables

# JWT Secret (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-min-64-characters

# MongoDB (optional - for production database)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/twinlink

# Cloudinary (optional - for image uploads)
# CLOUDINARY_CLOUD_NAME=your-cloud
# CLOUDINARY_API_KEY=your-key
# CLOUDINARY_API_SECRET=your-secret
